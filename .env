# Project
PROJECT_NAME="example"
CLONE_REPOSITORY="github.com/everynameistaken1/my-drupal-project.git"
CLONE_FLAGS="--depth 1"
THIRD_PARTY_MODULES_PROD="drupal/pathauto drupal/token drupal/webform drupal/admin_toolbar"
THIRD_PARTY_MODULES_DEV="drush/drush drupal/devel drupal/ctools"

# Available options:
# only-drupal - Has drupal. No xdebug, no neovim
# xdebug-vscode - Has drupal, xdebug, works with VsCode. No neovim
# xdebug-nvim - Has drupal, xdebug, neovim. Doesn't work with VsCode
DRUPAL_ENV="xdebug-nvim"

# Port you want to find your site on localhost:PORT
PORT="8080"

# Site
ACCOUNT_NAME="example"
ACCOUNT_MAIL="example@example.example"
SITE_MAIL="example@example.example"
SITE_NAME="example"

# Database Postgres
POSTGRES_USER="postgres"

POSTGRES_DB="postgres"
POSTGRES_PASSWORD_FILE="/run/secrets/postgres_pass"
POSTGRES_HOST="postgres"
POSTGRES_PORT="5432"
TABLE_EXISTS="users"

# Xdebug
XDEBUG_MODE="off"

# Git
GIT_EMAIL="example@email.com"
GIT_USERNAME="everynameistaken1"